{
  "name": "healthcare_lakehouse_medallion",
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "bronze_ingestion",
      "notebook_task": {
        "notebook_path": "/Repos/Healthcare_Lakehouse/notebooks/Bronze/01_bronze_ingestion",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "lakehouse_cluster"
    },
    {
      "task_key": "silver_transforms",
      "depends_on": [{"task_key": "bronze_ingestion"}],
      "notebook_task": {
        "notebook_path": "/Repos/Healthcare_Lakehouse/notebooks/Silver/01_silver_transformations",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "lakehouse_cluster"
    },
    {
      "task_key": "gold_analytics",
      "depends_on": [{"task_key": "silver_transforms"}],
      "notebook_task": {
        "notebook_path": "/Repos/Healthcare_Lakehouse/notebooks/Gold/01_gold_analytics",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "lakehouse_cluster"
    },
    {
      "task_key": "data_quality",
      "depends_on": [{"task_key": "silver_transforms"}],
      "notebook_task": {
        "notebook_path": "/Repos/Healthcare_Lakehouse/notebooks/DataQuality/01_data_quality_framework",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "lakehouse_cluster"
    },
    {
      "task_key": "monitoring_maintenance",
      "depends_on": [
        {"task_key": "gold_analytics"},
        {"task_key": "data_quality"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/Healthcare_Lakehouse/notebooks/Monitoring/01_monitoring_maintenance",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "lakehouse_cluster"
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "lakehouse_cluster",
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 2,
        "spark_conf": {
          "spark.sql.adaptive.enabled": "true",
          "spark.databricks.delta.optimizeWrite.enabled": "true",
          "spark.databricks.delta.autoCompact.enabled": "true",
          "spark.databricks.delta.schema.autoMerge.enabled": "true"
        }
      }
    }
  ]
}
