{
  "name": "ecommerce_lakehouse_medallion",
  "description": "Portable template. For Git-backed jobs keep source=GIT and repo-relative notebook_path under Databricks_pipeline/notebooks. For workspace clones, set source=WORKSPACE and notebook_path to the absolute /Workspace/... path of each notebook. No catalog/volume hardcoding — notebooks discover runtime env via ECOMMERCE_LAKEHOUSE_ROOT seed + bootstrap.",
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "generate_streaming_events",
      "notebook_task": {
        "notebook_path": "Databricks_pipeline/notebooks/00_generate_streaming_events",
        "source": "GIT"
      }
    },
    {
      "task_key": "bronze_ingestion",
      "depends_on": [{"task_key": "generate_streaming_events"}],
      "notebook_task": {
        "notebook_path": "Databricks_pipeline/notebooks/Bronze/01_bronze_ingestion",
        "source": "GIT"
      }
    },
    {
      "task_key": "silver_transforms",
      "depends_on": [{"task_key": "bronze_ingestion"}],
      "notebook_task": {
        "notebook_path": "Databricks_pipeline/notebooks/Silver/01_silver_transformations",
        "source": "GIT"
      }
    },
    {
      "task_key": "gold_analytics",
      "depends_on": [{"task_key": "silver_transforms"}],
      "notebook_task": {
        "notebook_path": "Databricks_pipeline/notebooks/Gold/01_gold_analytics",
        "source": "GIT"
      }
    },
    {
      "task_key": "structured_streaming",
      "depends_on": [{"task_key": "silver_transforms"}],
      "notebook_task": {
        "notebook_path": "Databricks_pipeline/notebooks/Streaming/01_structured_streaming",
        "source": "GIT"
      }
    },
    {
      "task_key": "data_quality",
      "depends_on": [{"task_key": "silver_transforms"}],
      "notebook_task": {
        "notebook_path": "Databricks_pipeline/notebooks/DataQuality/01_data_quality_framework",
        "source": "GIT"
      }
    },
    {
      "task_key": "monitoring_maintenance",
      "depends_on": [
        {"task_key": "gold_analytics"},
        {"task_key": "structured_streaming"},
        {"task_key": "data_quality"}
      ],
      "notebook_task": {
        "notebook_path": "Databricks_pipeline/notebooks/Monitoring/01_monitoring_maintenance",
        "source": "GIT"
      }
    }
  ],
  "performance_target": "STANDARD",
  "queue": {
    "enabled": true
  }
}
